{
  "name": "my-remotion-video",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "npm run gate:preproduction && npx remotion studio src/index.ts",
    "build": "npm run gate:preproduction && npx remotion render src/index.ts KnowledgeVideo --output=out/video-main.mp4 --codec=h264",
    "render:subs": "npm run gate:preproduction && npx remotion render src/index.ts KnowledgeVideoWithSubtitles --output=out/video-subs.mp4 --codec=h264",
    "cover:3x4": "npm run gate:preproduction && npx remotion still src/index.ts CoverImage3x4 --output=out/cover-3x4.png",
    "cover:4x3": "npm run gate:preproduction && npx remotion still src/index.ts CoverImage4x3 --output=out/cover-4x3.png",
    "generate-audio": "tsx src/video-system/scripts/generate-audio.ts",
    "generate-subtitles": "tsx src/video-system/scripts/generate-subtitles.ts",
    "director:cues:resolve": "tsx src/video-system/scripts/resolve-director-cues.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "validate:spec": "tsx src/video-system/scripts/validate-video-spec.ts",
    "validate:subs": "tsx src/video-system/scripts/validate-subtitles.ts",
    "validate:render": "tsx src/video-system/scripts/validate-render-code.ts",
    "validate:cover": "tsx src/video-system/scripts/validate-cover-spec.ts",
    "validate:all": "tsx src/video-system/scripts/check-ppt-tendency.ts && tsx src/video-system/scripts/validate-video-spec.ts && tsx src/video-system/scripts/validate-subtitles.ts && tsx src/video-system/scripts/validate-render-code.ts && tsx src/video-system/scripts/validate-cover-spec.ts",
    "check:ppt": "tsx src/video-system/scripts/check-ppt-tendency.ts",
    "capture:keyframes": "npm run gate:preproduction && tsx src/video-system/scripts/capture-keyframes.ts",
    "capture:keyframes:mobile": "npm run gate:preproduction && tsx src/video-system/scripts/capture-keyframes.ts --mobile",
    "tts:report": "tsx src/video-system/scripts/generate-tts-report.ts",
    "visual:metrics": "npm run gate:preproduction && tsx src/video-system/scripts/generate-visual-metrics.ts",
    "visual:check": "npm run gate:preproduction && tsx src/video-system/scripts/visual-check.ts",
    "contact:sheet": "npm run gate:preproduction && tsx src/video-system/scripts/generate-contact-sheet.ts",
    "contact:sheet:mobile": "npm run gate:preproduction && tsx src/video-system/scripts/generate-contact-sheet.ts --mobile --input-dir=out/keyframes/with-subtitles/mobile --output=out/keyframes/mobile_scaled_contact_sheet.jpg",
    "preview:visual": "tsx src/video-system/scripts/preview-visual.ts",
    "visual:fixtures": "tsx src/video-system/scripts/visual-fixtures.ts",
    "render:manifest": "npm run gate:preproduction && tsx src/video-system/scripts/generate-render-manifest.ts",
    "gate:preproduction": "tsx src/video-system/scripts/validate-preproduction-gate.ts",
    "validate:execution-ready": "npm run gate:preproduction && npm run validate:all",
    "validate:content": "tsx src/video-system/scripts/validate-content-brief.ts",
    "gate:preproduction:review": "tsx src/video-system/scripts/validate-preproduction-gate.ts --review-only",
    "promote:preproduction": "tsx src/video-system/scripts/promote-preproduction-candidates.ts",
    "validate:registry": "tsx src/video-system/scripts/validate-system-registry.ts",
    "validate:system": "npm run typecheck && npm test && npm run validate:registry && npm run validate:all && npm run validate:content -- src/video-system/fixtures/preproduction/contentBrief-reviewed-example.json && npm run gate:preproduction:review -- src/video-system/fixtures/preproduction/passing-example.json && npm run validate:agent-contracts",
    "prepare:preproduction": "tsx src/video-system/scripts/prepare-preproduction-review.ts",
    "refresh:preproduction-consensus": "tsx src/video-system/scripts/refresh-preproduction-consensus.ts",
    "studio:lab": "npx remotion studio src/lab.tsx",
    "packet:preproduction": "tsx src/video-system/scripts/generate-preproduction-review-packet.ts",
    "import:preproduction-review": "tsx src/video-system/scripts/import-preproduction-review.ts",
    "validate:quality": "tsx src/video-system/scripts/validate-quality-score.ts --draft",
    "gate:release": "tsx src/video-system/scripts/validate-quality-score.ts",
    "validate:agent-contracts": "tsx src/video-system/scripts/validate-agent-contracts.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@remotion/cli": "^4.0.469",
    "@remotion/google-fonts": "^4.0.469",
    "@remotion/player": "^4.0.469",
    "@remotion/transitions": "^4.0.469",
    "dotenv": "^17.4.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "node-edge-tts": "^1.2.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.469",
    "sharp": "^0.35.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
