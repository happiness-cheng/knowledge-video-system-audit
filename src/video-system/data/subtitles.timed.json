      "sceneId": "S10",
      "start": 184.517,
      "end": 185.993,
      "text": "大概分成四层。"
    },
    {
      "sceneId": "S10",
      "start": 185.993,
      "end": 186.836,
      "text": "第一层，"
    },
    {
      "sceneId": "S10",
      "start": 186.836,
      "end": 188.733,
      "text": "是身份和表达偏好。"
    },
    {
      "sceneId": "S10",
      "start": 188.733,
      "end": 191.262,
      "text": "比如默认中文，结论先行，"
    },
    {
      "sceneId": "S10",
      "start": 191.262,
      "end": 194.002,
      "text": "涉及外部资料要给官方依据。"
    },
    {
      "sceneId": "S10",
      "start": 194.002,
      "end": 194.845,
      "text": "第二层，"
    },
    {
      "sceneId": "S10",
      "start": 194.845,
      "end": 196.109,
      "text": "是行为准则。"
    },
    {
      "sceneId": "S10",
      "start": 196.109,
      "end": 198.427,
      "text": "比如实事求是，不迎合，"
    },
    {
      "sceneId": "S10",
      "start": 198.427,
      "end": 199.692,
      "text": "不顺手重构，"
    },
    {
      "sceneId": "S10",
      "start": 199.692,
      "end": 201.589,
      "text": "只改我要求的部分。"
    },
    {
      "sceneId": "S10",
      "start": 201.589,
      "end": 202.432,
      "text": "第三层，"
    },
    {
      "sceneId": "S10",
      "start": 202.432,
      "end": 203.696,
      "text": "是安全红线。"
    },
    {
      "sceneId": "S10",
      "start": 203.696,
      "end": 206.225,
      "text": "比如删除文件、修改密钥、"
    },
    {
      "sceneId": "S10",
      "start": 206.225,
      "end": 208.333,
      "text": "危险 git 操作、"
    },
    {
      "sceneId": "S10",
      "start": 208.333,
      "end": 211.284,
      "text": "数据库 migration，"
    },
    {
      "sceneId": "S10",
      "start": 211.284,
      "end": 212.759,
      "text": "都必须先确认。"
    },
    {
      "sceneId": "S10",
      "start": 212.759,
      "end": 213.602,
      "text": "第四层，"
    },
    {
      "sceneId": "S10",
      "start": 213.602,
      "end": 214.867,
      "text": "是纠错闭环。"
    },
    {
      "sceneId": "S10",
      "start": 214.867,
      "end": 216.131,
      "text": "如果是跨项目"
    },
    {
      "sceneId": "S10",
      "start": 216.131,
      "end": 218.028,
      "text": "都会反复犯的问题，"
    },
    {
      "sceneId": "S10",
      "start": 218.028,
      "end": 219.714,
      "text": "就写入全局经验。"
    },
    {
      "sceneId": "S10",
      "start": 219.714,
      "end": 221.821,
      "text": "如果只属于当前项目，"
    },
    {
      "sceneId": "S10",
      "start": 221.821,
      "end": 223.508,
      "text": "就写进项目规则。"
    },
    {
      "sceneId": "S10",
      "start": 223.508,
      "end": 225.615,
      "text": "如果只是一次性偏好，"
    },
    {
      "sceneId": "S10",
      "start": 225.615,
      "end": 226.88,
      "text": "就不要乱记。"
    },
    {
      "sceneId": "S10",
      "start": 226.88,
      "end": 229.198,
      "text": "你不需要照抄我的内容。"
    },
    {
      "sceneId": "S10",
      "start": 229.198,
      "end": 231.306,
      "text": "但你可以照这个结构，"
    },
    {
      "sceneId": "S10",
      "start": 231.306,
      "end": 232.57,
      "text": "给自己的项目"
    },
    {
      "sceneId": "S10",
      "start": 232.57,
      "end": 234.256,
      "text": "写一份员工手册。"
    },
    {
      "sceneId": "S11",
      "start": 234.256,
      "end": 236.323,
      "text": "因为聊天记录会结束。"
    },
    {
      "sceneId": "S11",
      "start": 236.323,
      "end": 237.562,
      "text": "项目会继续。"
    },
    {
      "sceneId": "S11",
      "start": 237.562,
      "end": 239.009,
      "text": "不要把项目知识"
    },
    {
      "sceneId": "S11",
      "start": 239.009,
      "end": 240.869,
      "text": "只留在聊天记录里。"
    },
    {
      "sceneId": "S11",
      "start": 240.869,
      "end": 242.935,
      "text": "打开你最常用的项目。"
    },
    {
      "sceneId": "S11",
      "start": 242.935,
      "end": 246.035,
      "text": "先写一份 CLAUDE.md。"
    },
    {
      "sceneId": "S11",
      "start": 246.035,
      "end": 249.754,
      "text": "让 Claude Code 先入职，"
    },
    {
      "sceneId": "S11",
      "start": 249.754,
      "end": 250.581,
      "text": "再干活。"
    },
    {
      "sceneId": "S11",
      "start": 250.581,
      "end": 251.614,
      "text": "快去试试。"
    }
  ]
}