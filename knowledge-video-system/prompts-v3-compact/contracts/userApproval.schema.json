{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "userApproval",
  "description": "用户批准，独立于 AI 审查",
  "type": "object",
  "required": [
    "contractVersion",
    "contentSnapshotId",
    "visualSnapshotId",
    "candidateDigest",
    "userDecision",
    "approvedByUser",
    "decisionNote",
    "decidedAt"
  ],
  "properties": {
    "contractVersion": { "type": "string", "const": "4.0" },
    "contentSnapshotId": { "type": "string" },
    "visualSnapshotId": { "type": "string" },
    "candidateDigest": { "type": "string" },
    "userDecision": {
      "type": "string",
      "enum": ["pending", "continue", "revise", "split", "stop"]
    },
    "approvedByUser": { "type": "boolean" },
    "decisionNote": { "type": "string" },
    "decidedAt": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
