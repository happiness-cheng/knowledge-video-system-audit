{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "visualDirectionSpec",
  "description": "视觉方向规格，包含完整的 V4 导演卡数组",
  "type": "object",
  "required": ["contractVersion", "contentSnapshotId", "shots"],
  "properties": {
    "contractVersion": { "type": "string", "const": "4.0" },
    "contentSnapshotId": { "type": "string" },
    "shots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "shotId",
          "beatId",
          "viewerStateBefore",
          "viewerStateAfter",
          "designRationale",
          "primaryVisualMode",
          "secondaryVisualMode",
          "explanationContribution",
          "comprehensionContribution",
          "attentionContribution",
          "audioVisualRelation",
          "spokenResponsibility",
          "visualResponsibility",
          "onScreenTextPurpose",
          "semanticEvent",
          "objects",
          "initialState",
          "stateChange",
          "finalState",
          "carryIn",
          "carryOut",
          "persistentObjects",
          "resetJustification",
          "truthMode",
          "evidenceAnchor",
          "evidenceBoundary",
          "lockedMeaning",
          "flexibleImplementation",
          "forbiddenDowngrade",
          "capabilityStatus",
          "capabilityGap",
          "negotiationLevel",
          "acceptanceCriteria",
          "requiredRenderEvidence"
        ],
        "properties": {
          "shotId": { "type": "string" },
          "beatId": { "type": "string" },
          "viewerStateBefore": { "type": "string" },
          "viewerStateAfter": { "type": "string" },
          "designRationale": { "type": "string" },
          "primaryVisualMode": { "type": "string" },
          "secondaryVisualMode": { "type": ["string", "null"] },
          "explanationContribution": { "type": "string" },
          "comprehensionContribution": { "type": "string" },
          "attentionContribution": { "type": "string" },
          "audioVisualRelation": {
            "type": "string",
            "enum": ["reinforce", "complement", "contrast", "evidence", "typographic-performance"]
          },
          "spokenResponsibility": { "type": "string" },
          "visualResponsibility": { "type": "string" },
          "onScreenTextPurpose": { "type": "string" },
          "semanticEvent": { "type": "string" },
          "objects": { "type": "array", "items": { "type": "string" } },
          "initialState": { "type": "string" },
          "stateChange": { "type": "string" },
          "finalState": { "type": "string" },
          "carryIn": { "type": "string" },
          "carryOut": { "type": "string" },
          "persistentObjects": { "type": "array", "items": { "type": "string" } },
          "resetJustification": { "type": ["string", "null"] },
          "truthMode": {
            "type": "string",
            "enum": ["fact", "experiment", "inference", "opinion", "analogy"]
          },
          "evidenceAnchor": { "type": ["string", "null"] },
          "evidenceBoundary": { "type": "string" },
          "lockedMeaning": { "type": "string" },
          "flexibleImplementation": { "type": "string" },
          "forbiddenDowngrade": { "type": "string" },
          "capabilityStatus": {
            "type": "string",
            "enum": ["confirmed", "needs-preflight", "gap"]
          },
          "capabilityGap": { "type": ["string", "null"] },
          "negotiationLevel": { "type": "string", "enum": ["L0", "L1", "L2", "L3"] },
          "acceptanceCriteria": { "type": "array", "items": { "type": "string" } },
          "requiredRenderEvidence": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
